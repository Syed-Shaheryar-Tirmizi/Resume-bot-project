# Required for the API server
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# Weaviate is required (no in-memory fallback).
# Option A — local instance: install/run Weaviate per https://weaviate.io/developers/weaviate/installation
#   then point host/ports below (defaults match a typical local install).
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# Option B — Weaviate Cloud (if set, WEAVIATE_API_KEY is required; host/ports above are ignored)
# WEAVIATE_URL=https://your-cluster.weaviate.network
# WEAVIATE_API_KEY=
# WEAVIATE_TIMEOUT_INIT=90
# WEAVIATE_SKIP_INIT_CHECKS=false

# Optional: Google Cloud Speech-to-Text (not wired in this scaffold; Whisper is used)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\service-account.json

# Full build only (~40% submission keeps these off):
# ENABLE_CV_DOMAIN_TRANSFORM=true
# ENABLE_VOICE_INPUT=true
